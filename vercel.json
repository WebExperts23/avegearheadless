{
    "rewrites": [
        {
            "source": "/checkout(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/checkout$1"
        },
        {
            "source": "/static/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/static/$1"
        },
        {
            "source": "/media/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/media/$1"
        },
        {
            "source": "/customer/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/customer/$1"
        },
        {
            "source": "/customer/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/customer/$1"
        },
        {
            "source": "/catalog/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/catalog/$1"
        },
        {
            "source": "/rest/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/rest/$1"
        },
        {
            "source": "/magento-api/(.*)",
            "destination": "https://2fc1869dd5.nxcli.io/$1"
        },
        {
            "source": "/graphql",
            "destination": "https://2fc1869dd5.nxcli.io/graphql"
        },
        {
            "source": "/((?!checkout|static|media|customer|catalog|rest|magento-api|graphql|assets).*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/assets/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        },
        {
            "source": "/(.*).(png|jpg|jpeg|gif|webp|avif|svg|ico)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, must-revalidate"
                }
            ]
        },
        {
            "source": "/(.*).(woff|woff2|eot|ttf|otf)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=31536000, immutable"
                }
            ]
        }
    ]
}